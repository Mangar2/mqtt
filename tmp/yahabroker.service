[Unit]
Description=Yaha MQTT Broker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/home/pi/mqtt
ExecStart=/home/pi/mqtt/yahabroker -c /home/pi/mqtt/broker.ini
Restart=always
RestartSec=3
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target