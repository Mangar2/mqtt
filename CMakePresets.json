{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER":            "clang++",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },

    {
      "name":        "debug",
      "displayName": "Debug (host)",
      "inherits":    "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING":    "ON"
      }
    },

    {
      "name":        "release",
      "displayName": "Release (host)",
      "inherits":    "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING":    "OFF"
      }
    },

    {
      "name":        "debug-sanitize",
      "displayName": "Debug + Sanitizers (host)",
      "inherits":    "debug",
      "cacheVariables": {
        "MQTT_SANITIZE": "ON"
      }
    },

    {
      "name":        "test-coverage",
      "displayName": "Test + Coverage (host, Debug)",
      "inherits":    "debug",
      "cacheVariables": {
        "MQTT_COVERAGE": "ON",
        "MQTT_TRACING_DISABLED": "ON"
      }
    },

    {
      "name":          "arm-base",
      "hidden":        true,
      "inherits":      "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/arm-linux-gnueabihf.cmake",
      "cacheVariables": {
        "BUILD_TESTING": "OFF"
      }
    },

    {
      "name":          "armv6-base",
      "hidden":        true,
      "inherits":      "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/armv6-linux-gnueabihf.cmake",
      "environment": {
        "ARM_SYSROOT": "${sourceDir}/.sysroots/rpi-armv6-trixie"
      },
      "cacheVariables": {
        "BUILD_TESTING": "OFF"
      }
    },

    {
      "name":        "arm-debug",
      "displayName": "Debug (Raspberry Pi Zero 2 – ARM 32-bit)",
      "inherits":    "arm-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },

    {
      "name":        "arm-release",
      "displayName": "Release (Raspberry Pi Zero 2 – ARM 32-bit)",
      "inherits":    "arm-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },

    {
      "name":        "armv6-debug",
      "displayName": "Debug (Raspberry Pi Zero/1 – ARMv6 32-bit)",
      "inherits":    "armv6-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },

    {
      "name":        "armv6-release",
      "displayName": "Release (Raspberry Pi Zero/1 – ARMv6 32-bit)",
      "inherits":    "armv6-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],

  "buildPresets": [
    { "name": "debug",          "displayName": "Build Debug (host)",                  "configurePreset": "debug"          },
    { "name": "release",        "displayName": "Build Release (host)",                "configurePreset": "release"        },
    { "name": "debug-sanitize", "displayName": "Build Debug + Sanitizers (host)",     "configurePreset": "debug-sanitize" },
    { "name": "test-coverage",  "displayName": "Build Tests + Coverage (host)",       "configurePreset": "test-coverage"  },
    { "name": "arm-debug",      "displayName": "Build Debug (ARM 32-bit)",            "configurePreset": "arm-debug"      },
    { "name": "arm-release",    "displayName": "Build Release (ARM 32-bit)",          "configurePreset": "arm-release"    },
    { "name": "armv6-debug",    "displayName": "Build Debug (ARMv6 32-bit)",          "configurePreset": "armv6-debug"    },
    { "name": "armv6-release",  "displayName": "Build Release (ARMv6 32-bit)",        "configurePreset": "armv6-release"  }
  ],

  "testPresets": [
    {
      "name":            "debug",
      "displayName":     "Run Tests (host)",
      "configurePreset": "debug",
      "output":          { "outputOnFailure": true }
    },
    {
      "name":            "test-coverage",
      "displayName":     "Run Tests + Coverage (host)",
      "configurePreset": "test-coverage",
      "output":          { "outputOnFailure": true }
    }
  ]
}
