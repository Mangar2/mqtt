{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },

    {
      "name":        "debug",
      "displayName": "Debug (host)",
      "inherits":    "base",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING":    "ON"
      }
    },

    {
      "name":        "release",
      "displayName": "Release (host)",
      "inherits":    "base",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING":    "OFF"
      }
    },

    {
      "name":        "release-dbg",
      "displayName": "Release with Debug Symbols (host)",
      "inherits":    "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_TESTING":    "OFF"
      }
    },

    {
      "name":        "debug-sanitize",
      "displayName": "Debug + Sanitizers (host)",
      "inherits":    "debug",
      "cacheVariables": {
        "MQTT_SANITIZE": "ON"
      }
    },

    {
      "name":        "test-coverage",
      "displayName": "Test + Coverage (host, Debug)",
      "inherits":    "debug",
      "cacheVariables": {
        "MQTT_COVERAGE": "ON",
        "MQTT_TRACING_DISABLED": "ON"
      }
    },

    {
      "name":          "armv6-zig-base",
      "hidden":        true,
      "inherits":      "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/armv6-zig.cmake",
      "cacheVariables": {
        "BUILD_TESTING": "OFF"
      }
    },

    {
      "name":        "armv6-zig-debug",
      "displayName": "Debug (Raspberry Pi Zero/1 – ARMv6, Zig, no sysroot)",
      "inherits":    "armv6-zig-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },

    {
      "name":        "armv6-zig-release",
      "displayName": "Release (Raspberry Pi Zero/1 – ARMv6, Zig, no sysroot)",
      "inherits":    "armv6-zig-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },

    {
      "name":          "armv7-zig-base",
      "hidden":        true,
      "inherits":      "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/armv7-zig.cmake",
      "cacheVariables": {
        "BUILD_TESTING": "OFF"
      }
    },

    {
      "name":        "armv7-zig-debug",
      "displayName": "Debug (Raspberry Pi Zero 2 – ARMv7, Zig, no sysroot)",
      "inherits":    "armv7-zig-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },

    {
      "name":        "armv7-zig-release",
      "displayName": "Release (Raspberry Pi Zero 2 – ARMv7, Zig, no sysroot)",
      "inherits":    "armv7-zig-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],

  "buildPresets": [
    { "name": "debug",          "displayName": "Build Debug (host)",                  "configurePreset": "debug"          },
    { "name": "release",        "displayName": "Build Release (host)",                "configurePreset": "release"        },
    { "name": "debug-sanitize", "displayName": "Build Debug + Sanitizers (host)",     "configurePreset": "debug-sanitize" },
    { "name": "test-coverage",  "displayName": "Build Tests + Coverage (host)",       "configurePreset": "test-coverage"  },
    { "name": "armv6-zig-debug",   "displayName": "Build Debug (ARMv6, Zig)",           "configurePreset": "armv6-zig-debug"  },
    { "name": "armv6-zig-release", "displayName": "Build Release (ARMv6, Zig)",         "configurePreset": "armv6-zig-release" },
    { "name": "armv7-zig-debug",   "displayName": "Build Debug (ARMv7, Zig)",           "configurePreset": "armv7-zig-debug"  },
    { "name": "armv7-zig-release", "displayName": "Build Release (ARMv7, Zig)",         "configurePreset": "armv7-zig-release" }
  ],

  "testPresets": [
    {
      "name":            "debug",
      "displayName":     "Run Tests (host)",
      "configurePreset": "debug",
      "output":          { "outputOnFailure": true }
    },
    {
      "name":            "test-coverage",
      "displayName":     "Run Tests + Coverage (host)",
      "configurePreset": "test-coverage",
      "output":          { "outputOnFailure": true }
    }
  ]
}
