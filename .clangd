CompileFlags:
  # Fallback flags used when a file is NOT in compile_commands.json.
  # The real flags (including -std=c++20 and include paths) come from
  # build/debug/compile_commands.json which is configured in .vscode/settings.json.
  Add:
    - "-std=c++20"
    - "-Isrc"
    - "-Wall"
    - "-Wextra"

Diagnostics:
  # Suppress noisy clang-tidy checks that are not relevant for this project.
  ClangTidy:
    Add:
      - modernize-*
      - readability-*
      - performance-*
    Remove:
      - modernize-use-trailing-return-type
      - readability-magic-numbers
