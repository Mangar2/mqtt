CompileFlags:
  # Prefer the debug preset compilation database after configure.
  # If it is missing (fresh clone before first configure), fallback flags below apply.
  CompilationDatabase: build/debug
  Add:
    - "-std=c++20"
    - "-Isrc"
    - "-Wall"
    - "-Wextra"
    - "-Wmissing-field-initializers"

Diagnostics:
  # Suppress noisy clang-tidy checks that are not relevant for this project.
  ClangTidy:
    # Run the full clang-tidy set (not only fast checks), so style checks
    # like modernize-raw-string-literal appear as diagnostics in Problems.
    FastCheckFilter: Loose
    Add:
      - modernize-raw-string-literal
      - modernize-*
      - readability-*
      - performance-*
    Remove:
      - modernize-use-trailing-return-type
      - readability-redundant-member-init
      - readability-redundant-string-init
